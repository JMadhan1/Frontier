# Frontier Trade Hub Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# NETWORK CONFIGURATION
# ===========================================

# The network to connect to: 'utopia' (testnet), 'stillness' (mainnet), or 'devnet' (Sui testnet)
VITE_NETWORK=devnet

# ===========================================
# CONTRACT ADDRESSES
# ===========================================

# TradeHub Package ID (deployed contract address)
# Devnet (Sui Testnet - fallback)
VITE_TRADE_HUB_PACKAGE_ID_DEVNET=0x0

# Utopia (EVE Frontier Testnet)
VITE_TRADE_HUB_PACKAGE_ID_UTOPIA=0x0

# Stillness (Mainnet) - For production deployment
VITE_TRADE_HUB_PACKAGE_ID_STILLNESS=0x0

# TradeHub Shared Object ID
VITE_TRADE_HUB_OBJECT_ID_DEVNET=0x0
VITE_TRADE_HUB_OBJECT_ID_UTOPIA=0x0
VITE_TRADE_HUB_OBJECT_ID_STILLNESS=0x0

# ===========================================
# SUI NETWORK RPC ENDPOINTS
# ===========================================

# Sui Testnet (default fallback)
VITE_SUI_RPC_DEVNET=https://fullnode.testnet.sui.io

# Utopia Testnet RPC (EVE Frontier)
VITE_SUI_RPC_UTOPIA=https://rpc.utopia.evefrontier.com

# Stillness Mainnet RPC (EVE Frontier)
VITE_SUI_RPC_STILLNESS=https://rpc.stillness.evefrontier.com

# ===========================================
# OPTIONAL CONFIGURATION
# ===========================================

# Enable debug logging
VITE_DEBUG=false

# Analytics tracking ID (optional)
VITE_ANALYTICS_ID=
