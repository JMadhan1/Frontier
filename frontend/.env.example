# Frontier Trade Hub - Environment Variables
# Copy this file to .env and fill in your values
# All VITE_ variables are exposed to the browser bundle

# Network: devnet | testnet | utopia | stillness
VITE_NETWORK=devnet

# Contract addresses (Sui Devnet - deployed 2026-03-30)
VITE_TRADE_HUB_PACKAGE_ID_DEVNET=0x332ee2997d16a70955c39b96df11634cd76053d61252e052933f661de0781a37
VITE_TRADE_HUB_PACKAGE_ID_UTOPIA=0x0
VITE_TRADE_HUB_PACKAGE_ID_STILLNESS=0x0

VITE_TRADE_HUB_OBJECT_ID_DEVNET=0x6660bee0e8a51f468d4339d9be070f951e063f9e851d66519eea7eefeebb5b42
VITE_TRADE_HUB_OBJECT_ID_UTOPIA=0x0
VITE_TRADE_HUB_OBJECT_ID_STILLNESS=0x0

# SUI RPC endpoints
VITE_SUI_RPC_DEVNET=https://fullnode.devnet.sui.io:443
VITE_SUI_RPC_UTOPIA=https://rpc.utopia.evefrontier.com
VITE_SUI_RPC_STILLNESS=https://rpc.stillness.evefrontier.com

# Optional
VITE_DEBUG=false
VITE_ANALYTICS_ID=
